#!/bin/sh
# Inner wrapper for opencode - invoked by the user-facing wrapper.
# Sets LD_LIBRARY_PATH so the musl dynamic linker can find bundled libs,
# and LD_PRELOAD to load clear_ldpath.so which removes LD_PRELOAD from
# the environment (preventing the .so from propagating to descendants).

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

LD_PRELOAD="${SCRIPT_DIR}/lib/clear_ldpath.so" \
    LD_LIBRARY_PATH="${SCRIPT_DIR}/lib" \
    exec "${SCRIPT_DIR}/lib/opencode" "$@"
